# Server
MCP__HOST=0.0.0.0
MCP__PORT=8085
LOG_LEVEL=info

# Auth - comma-separated tokens (required when auth.enabled=true)
AUTH_TOKENS=replace_me_with_a_strong_token

# Limits
MCP__LIMITS__MAX_REQUEST_BYTES=1048576
MCP__LIMITS__MAX_BATCH_SIZE=50
MCP__LIMITS__GLOBAL_CONCURRENCY=256
MCP__LIMITS__PER_TOOL_TIMEOUT_SECS=30
MCP__LIMITS__CLASSIFY_TIMEOUT_SECS=5

# Optional: Redis (for distributed caching)
# MCP__REDIS__URL=redis://localhost:6379

# Optional: PostgreSQL (for feedback/audit persistence)
# Format: ******HOST:5432/DBNAME
# MCP__POSTGRES__URL=<scheme>://<user>:<pass>@localhost:5432/mcp

# Optional: GeoIP (MaxMind MMDB path)
# MCP__GEOIP__MMDB_PATH=/data/GeoLite2-City.mmdb

# Optional: OpenTelemetry
# MCP__TELEMETRY__OTLP_ENDPOINT=http://otel-collector:4317
MCP__TELEMETRY__SERVICE_NAME=ai-scraping-defense-mcp

# Feature flags
MCP__FEATURES__ENABLE_BATCH=true
MCP__FEATURES__ENABLE_ENRICHMENT=true
MCP__FEATURES__ENABLE_FEEDBACK=true

# Client repos - these env vars go in the consuming service, not this server
# MODEL_URI=mcp://primary/classify
# MCP_SERVER_PRIMARY_TRANSPORT=ws
# MCP_SERVER_PRIMARY_URL=ws://ai-scraping-defense-mcp:8085/mcp
# MCP_SERVER_PRIMARY_AUTH_TOKEN=replace_me
# MCP_SERVER_PRIMARY_TIMEOUT=10
