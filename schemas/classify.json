{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClassifyRequest",
  "type": "object",
  "properties": {
    "ip": { "type": "string", "description": "Client IP address" },
    "user_agent": { "type": "string", "description": "HTTP User-Agent header value" },
    "path": { "type": "string", "description": "Request path" },
    "method": { "type": "string", "enum": ["GET","POST","PUT","PATCH","DELETE","HEAD","OPTIONS"] },
    "headers": { "type": "object", "additionalProperties": { "type": "string" } },
    "body_snippet": { "type": "string", "description": "First 512 bytes of request body" },
    "referer": { "type": "string" },
    "accept": { "type": "string" },
    "request_id": { "type": "string", "description": "Optional idempotency / correlation ID" },
    "timestamp": { "type": "string", "format": "date-time" },
    "extra": { "type": "object", "description": "Arbitrary extra signals" }
  }
}
